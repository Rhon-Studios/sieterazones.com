generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Animal {
  id               Int            @id @default(autoincrement())
  name             String
  shortDescription String
  description      String
  years            Int
  months           Int
  sex              String
  status           String
  priority         String
  isAdopted        Boolean
  images           ImagesAnimal[]
}

model ImagesAnimal {
  id       Int    @id @default(autoincrement())
  url      String
  animalId Int
  animal   Animal @relation(fields: [animalId], references: [id])
}
